# SHOWBAY Email Marketing System - Environment Variables
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# MongoDB Connection (Use MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/showbay
# For Render/Production: mongodb+srv://username:password@cluster.mongodb.net/showbay

# Session Secret (change this to a strong random string for production)
SESSION_SECRET=showbay-super-secret-key-change-this-in-production-2024

# SMTP Configuration for Email Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=SHOWBAY Email Marketing
APP_PASSWORD=your-app-password

# Admin Credentials (for development)
ADMIN_PASSWORD=showbay2024

# Render Deployment Variables (set these in Render dashboard)
# PORT=10000
# NODE_ENV=production
# MONGO_URI=your-mongodb-atlas-connection-string
# SESSION_SECRET=your-strong-production-secret
